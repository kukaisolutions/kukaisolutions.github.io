---
import { useTranslations } from '@i18n/ui';
import type { Lang } from '@i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const values = [
  { label: t('manifesto.value1.label'), body: t('manifesto.value1.body') },
  { label: t('manifesto.value2.label'), body: t('manifesto.value2.body') },
  { label: t('manifesto.value3.label'), body: t('manifesto.value3.body') },
  { label: t('manifesto.value4.label'), body: t('manifesto.value4.body') },
  { label: t('manifesto.value5.label'), body: t('manifesto.value5.body') },
  { label: t('manifesto.value6.label'), body: t('manifesto.value6.body') },
  { label: t('manifesto.value7.label'), body: t('manifesto.value7.body') },
];
---

<section
  id="manifesto"
  class="flex flex-col items-center py-20 lg:flex-row lg:gap-12"
>
  <div class="mb-8 flex flex-col items-center lg:mb-0 lg:w-1/4 lg:items-start">
    <h2 class="font-monospace text-2xl text-orange lg:text-4xl">{t('manifesto.title')}</h2>
    <span class="mb-6 mt-2 h-1 w-10 bg-orange"></span>
  </div>

  <div class="w-full max-w-2xl text-black dark:text-white lg:w-3/5">
    <p class="mb-6 text-justify opacity-80">
      {t('manifesto.intro')}
    </p>
    <ul class="space-y-5">
      {
        values.map((v) => (
          <li class="flex gap-4">
            <span class="mt-1 h-2 w-2 flex-shrink-0 rounded-full bg-orange" />
            <p class="text-sm leading-relaxed opacity-80">
              <span class="font-semibold text-orange opacity-100">{v.label}:</span>{' '}
              <span set:html={v.body} />
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
