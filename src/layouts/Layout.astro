---
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import { SEO } from 'astro-seo';
import type { Lang } from '@i18n/ui';

export interface Props {
  title?: string;
  description?: string;
  lang: Lang;
}

const {
  title = 'Kukai Solutions',
  description = 'Data-driven solutions that transform complex challenges into measurable results.',
  lang,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <SEO title={title} description={description} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/logo_kukaisolutions.png" />
    <title>{title}</title>
  </head>
  <body
    class="mx-auto max-w-screen-xl bg-white text-black dark:bg-black dark:text-white px-5 font-sans xs:text-[16px] md:text-[18px] flex flex-col min-h-screen"
  >
    <Navbar lang={lang} />
    <slot />
    <Footer lang={lang} />

    <style is:global>
      img {
        content-visibility: auto;
      }
    </style>

    <script>
      const html = document.documentElement;
      html.classList.remove('dark');

      window.toggleTheme = () => {
        html.classList.toggle('dark');
        localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
      };
    </script>
  </body>
</html>
