---
import { Icon } from 'astro-icon/components';
import { useTranslations } from '@i18n/ui';
import type { Lang } from '@i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const cards = [
  {
    icon: 'mdi:brain',
    title: t('services.ml.title'),
    description: t('services.ml.description'),
  },
  {
    icon: 'mdi:text-box-search-outline',
    title: t('services.nlp.title'),
    description: t('services.nlp.description'),
  },
  {
    icon: 'mdi:cog-outline',
    title: t('services.process.title'),
    description: t('services.process.description'),
  },
  {
    icon: 'mdi:chart-line',
    title: t('services.analytics.title'),
    description: t('services.analytics.description'),
  },
];

const bullets = [
  t('about.bullet1'),
  t('about.bullet2'),
  t('about.bullet3'),
  t('about.bullet4'),
] as const;
---

<section class="flex flex-col justify-center py-20">

  <!-- Intro -->
  <div class="mb-16 flex flex-col items-center justify-center lg:flex-row lg:gap-12">
    <div class="mb-8 flex flex-col items-center lg:mb-0 lg:w-1/4 lg:items-start">
      <h2 class="font-monospace text-2xl text-orange lg:text-4xl">{t('techniques.title')}</h2>
      <span class="mb-6 mt-2 h-1 w-10 bg-orange"></span>
    </div>

    <div class="w-full max-w-4xl text-justify text-black dark:text-white lg:w-3/4 space-y-4">
      <p>{t('about.p1')}</p>
      <p>{t('about.p2')}</p>
      <p>{t('about.p3')}</p>
      <ul class="mt-4 list-disc pl-6 space-y-1 text-orange">
        {bullets.map((b) => (
          <li><span class="text-black dark:text-white">{b}</span></li>
        ))}
      </ul>
    </div>
  </div>

  <!-- Technique cards -->
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 max-w-4xl mx-auto w-full">
    {
      cards.map((card) => (
        <div class="rounded-2xl border border-gray-200 dark:border-gray-700 p-6 transition-shadow hover:shadow-lg dark:hover:shadow-orange/10">
          <Icon name={card.icon} class="mb-4 h-10 w-10 text-orange" />
          <h3 class="mb-2 text-lg font-bold text-black dark:text-white">{card.title}</h3>
          <p class="text-sm text-black dark:text-white opacity-70 leading-relaxed">
            {card.description}
          </p>
        </div>
      ))
    }
  </div>

</section>
