---
import { useTranslations } from '@i18n/ui';
import type { Lang } from '@i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const steps = [
  { title: t('plans.step1.title'), body: t('plans.step1.body') },
  { title: t('plans.step2.title'), body: t('plans.step2.body') },
  { title: t('plans.step3.title'), body: t('plans.step3.body') },
];

const tableRows = [
  [t('plans.table.row1.label'), t('plans.table.row1.a'), t('plans.table.row1.b')],
  [t('plans.table.row2.label'), t('plans.table.row2.a'), t('plans.table.row2.b')],
  [t('plans.table.row3.label'), t('plans.table.row3.a'), t('plans.table.row3.b')],
  [t('plans.table.row4.label'), t('plans.table.row4.a'), t('plans.table.row4.b')],
  [t('plans.table.row5.label'), t('plans.table.row5.a'), t('plans.table.row5.b')],
  [t('plans.table.row6.label'), t('plans.table.row6.a'), t('plans.table.row6.b')],
  [t('plans.table.row7.label'), t('plans.table.row7.a'), t('plans.table.row7.b')],
];

const pricing = [
  { label: t('plans.pricing.item1.label'), price: '$100 – $1,000', unit: t('plans.pricing.item1.unit') },
  { label: t('plans.pricing.item2.label'), price: '$1K – $10K',    unit: t('plans.pricing.item2.unit') },
  { label: t('plans.pricing.item3.label'), price: '$50 – $200',    unit: t('plans.pricing.item3.unit') },
];
---

<section
  id="plans"
  class="flex flex-col items-center py-20"
>

  <!-- How We Work -->
  <div class="mb-20 w-full max-w-2xl">
    <div class="mb-10 flex flex-col items-center text-center">
      <h2 class="font-monospace text-2xl text-orange lg:text-4xl">{t('plans.howwework.title')}</h2>
      <span class="mb-4 mt-2 h-1 w-10 bg-orange"></span>
      <p class="text-black dark:text-white opacity-70 max-w-lg">
        {t('plans.howwework.subtitle')}
      </p>
    </div>

    <ol class="space-y-6 text-black dark:text-white">
      {
        steps.map((step, i) => (
          <li class="flex gap-5">
            <span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-orange text-sm font-bold text-white">
              {i + 1}
            </span>
            <div>
              <p class="font-semibold">{step.title}</p>
              <p class="mt-1 text-sm opacity-70 leading-relaxed">{step.body}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>

  <!-- Collaboration models -->
  <div class="mb-20 w-full max-w-2xl">
    <div class="mb-8 flex flex-col items-center text-center">
      <h3 class="font-monospace text-xl text-orange lg:text-3xl">{t('plans.collab.title')}</h3>
      <span class="mb-4 mt-2 h-1 w-10 bg-orange"></span>
    </div>

    <div class="mb-8 space-y-4 text-black dark:text-white text-sm leading-relaxed">
      <p>
        <span class="font-semibold text-orange">{t('plans.plana.label')}</span>{' '}
        {t('plans.plana.body')}
      </p>
      <p>
        <span class="font-semibold text-orange">{t('plans.planb.label')}</span>{' '}
        {t('plans.planb.body')}
      </p>
    </div>

    <div class="overflow-x-auto">
      <table class="w-full text-sm text-black dark:text-white border-collapse">
        <thead>
          <tr class="border-b border-gray-300 dark:border-gray-700">
            <th class="py-3 pr-4 text-left font-medium opacity-50 w-1/4"></th>
            <th class="py-3 px-4 text-left font-semibold text-orange">{t('plans.table.header.plana')}</th>
            <th class="py-3 px-4 text-left font-semibold text-orange">{t('plans.table.header.planb')}</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          {
            tableRows.map(([label, a, b]) => (
              <tr>
                <td class="py-3 pr-4 font-medium opacity-60">{label}</td>
                <td class="py-3 px-4 opacity-80">{a}</td>
                <td class="py-3 px-4 opacity-80">{b}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>

  <!-- Pricing -->
  <div class="w-full max-w-2xl">
    <div class="mb-8 flex flex-col items-center text-center">
      <h3 class="font-monospace text-xl text-orange lg:text-3xl">{t('plans.pricing.title')}</h3>
      <span class="mb-4 mt-2 h-1 w-10 bg-orange"></span>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      {
        pricing.map((p) => (
          <div class="rounded-2xl border border-gray-200 dark:border-gray-700 p-6 text-black dark:text-white">
            <p class="mb-2 text-sm font-semibold text-orange">{p.label}</p>
            <p class="text-2xl font-bold">{p.price}</p>
            <p class="mt-1 text-xs opacity-50">{p.unit}</p>
          </div>
        ))
      }
    </div>

    <p class="mt-6 text-center text-xs text-black dark:text-white opacity-40">
      {t('plans.pricing.disclaimer')}
    </p>
  </div>

</section>
