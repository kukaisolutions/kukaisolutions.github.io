---
import { useTranslations } from '@i18n/ui';
import type { Lang } from '@i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const items = [
  { label: t('complexities.item1.label'), body: t('complexities.item1.body') },
  { label: t('complexities.item2.label'), body: t('complexities.item2.body') },
  { label: t('complexities.item3.label'), body: t('complexities.item3.body') },
  { label: t('complexities.item4.label'), body: t('complexities.item4.body') },
  { label: t('complexities.item5.label'), body: t('complexities.item5.body') },
  { label: t('complexities.item6.label'), body: t('complexities.item6.body') },
  { label: t('complexities.item7.label'), body: t('complexities.item7.body') },
];
---

<section
  id="complexities"
  class="flex flex-col items-center py-20 lg:flex-row lg:gap-12"
>
  <div class="mb-8 flex flex-col items-center lg:mb-0 lg:w-1/4 lg:items-start">
    <h2 class="font-monospace text-2xl text-orange lg:text-4xl">{t('complexities.title')}</h2>
    <span class="mb-6 mt-2 h-1 w-10 bg-orange"></span>
  </div>

  <div class="w-full max-w-2xl text-black dark:text-white lg:w-3/5">
    <p class="mb-6 text-justify opacity-80">
      {t('complexities.intro')}
    </p>
    <ol class="space-y-4">
      {
        items.map((item, i) => (
          <li class="flex gap-4">
            <span class="mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-orange text-xs font-bold text-white">
              {i + 1}
            </span>
            <p class="text-sm leading-relaxed opacity-80">
              <span class="font-semibold opacity-100">{item.label}:</span> {item.body}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
