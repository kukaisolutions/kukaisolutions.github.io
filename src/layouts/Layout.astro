---
import Navbar from '@components/Navbar.astro';
import Footer from '@components/Footer.astro';
import { SEO } from 'astro-seo';
import type { Lang } from '@i18n/ui';

export interface Props {
  title?: string;
  description?: string;
  lang: Lang;
}

const {
  title = 'Kukai Solutions',
  description = 'Data-driven solutions that transform complex challenges into measurable results.',
  lang,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} class="scroll-smooth">
  <head>
    <SEO title={title} description={description} />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/logo_kukaisolutions.png" />
    <title>{title}</title>
  </head>
  <body
    class="mx-auto max-w-screen-xl text-black dark:text-white px-5 font-sans xs:text-[16px] md:text-[18px] flex flex-col min-h-screen"
  >
    <Navbar lang={lang} />
    <slot />
    <Footer lang={lang} />

    <style is:global>
      img {
        content-visibility: auto;
      }

      :root {
        --penrose-light-overlay: 0.78; /* 0 = full pattern, 1 = pure white */
        --penrose-dark-overlay: 0.78;  /* 0 = full pattern, 1 = pure black */
      }

      html {
        background-image:
          linear-gradient(
            rgba(255, 255, 255, var(--penrose-light-overlay)),
            rgba(255, 255, 255, var(--penrose-light-overlay))
          ),
          url('/images/penrose_tiling.jpg');
        background-repeat: repeat;
        background-attachment: fixed;
      }

      html.dark {
        background-image:
          linear-gradient(
            rgba(0, 0, 0, var(--penrose-dark-overlay)),
            rgba(0, 0, 0, var(--penrose-dark-overlay))
          ),
          url('/images/penrose_tiling.jpg');
      }
    </style>

    <script>
      declare global { interface Window { toggleTheme: () => void; } }

      const html = document.documentElement;
      html.classList.remove('dark');

      window.toggleTheme = () => {
        html.classList.toggle('dark');
        localStorage.setItem('theme', html.classList.contains('dark') ? 'dark' : 'light');
      };
    </script>
  </body>
</html>
