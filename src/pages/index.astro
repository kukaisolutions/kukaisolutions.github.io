---
import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import About from '@components/About.astro';
import Complexities from '@components/Complexities.astro';
import EthosAndValues from '@components/EthosAndValues.astro';
import Plans from '@components/Plans.astro';
import Contact from '@components/Contact.astro';
import BackToTop from '@components/ui/BackToTop.astro';

const lang = 'en' as const;
---

<Layout
  lang={lang}
  title="Kukai Solutions | Software for Small Businesses"
  description="Software solutions for small businesses and their unique complexities."
>
  <main>
    <Hero lang={lang} />
    <About lang={lang} />
    <Complexities lang={lang} />
    <EthosAndValues lang={lang} />
    <Plans lang={lang} />
    <Contact lang={lang} />
  </main>
  <BackToTop />
</Layout>
