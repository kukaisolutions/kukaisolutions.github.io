---
import { Icon } from 'astro-icon/components';
import { useTranslations } from '@i18n/ui';
import type { Lang } from '@i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const services = [
  {
    icon: 'mdi:brain',
    title: t('services.ml.title'),
    description: t('services.ml.description'),
  },
  {
    icon: 'mdi:text-box-search-outline',
    title: t('services.nlp.title'),
    description: t('services.nlp.description'),
  },
  {
    icon: 'mdi:cog-outline',
    title: t('services.process.title'),
    description: t('services.process.description'),
  },
  {
    icon: 'mdi:chart-line',
    title: t('services.analytics.title'),
    description: t('services.analytics.description'),
  },
];
---

<section
  id="services"
  class="flex flex-col justify-center py-20 lg:min-h-screen"
>
  <!-- Section heading -->
  <div class="mb-12 flex flex-col items-center text-center">
    <h2 class="font-monospace text-2xl text-orange lg:text-4xl">{t('services.title')}</h2>
    <span class="mb-4 mt-2 h-1 w-10 bg-orange"></span>
    <p class="text-base text-black dark:text-white opacity-70 max-w-lg">
      {t('services.subtitle')}
    </p>
  </div>

  <!-- Cards grid -->
  <div class="grid grid-cols-1 gap-8 md:grid-cols-2 max-w-4xl mx-auto w-full">
    {
      services.map((service) => (
        <div class="rounded-2xl border border-gray-200 dark:border-gray-700 p-6 transition-shadow hover:shadow-lg dark:hover:shadow-orange/10">
          <Icon name={service.icon} class="mb-4 h-10 w-10 text-orange" />
          <h3 class="mb-2 text-lg font-bold text-black dark:text-white">{service.title}</h3>
          <p class="text-sm text-black dark:text-white opacity-70 leading-relaxed">
            {service.description}
          </p>
        </div>
      ))
    }
  </div>
</section>
